# MCP KG Inquirer - Test Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Required Configuration
# =============================================================================

# Knowledge Graph Engine endpoint ID
KGE_ENDPOINT_ID=test-endpoint

# Partition ID for tenant isolation
KGE_PART_ID=test-partition

# =============================================================================
# Authentication (provide ONE of the following)
# =============================================================================

# Option 1: API Key authentication
KGE_API_KEY=your-api-key-here

# Option 2: Bearer Token authentication (OAuth/JWT)
# Preferred for production environments
# KGE_BEARER_TOKEN=your-jwt-token-here

# =============================================================================
# Optional Configuration
# =============================================================================

# Base URL for the Knowledge Graph Engine API
# Default: http://localhost:8000
KGE_BASE_URL=http://localhost:8000

# Request timeout in seconds
# Default: 30.0
KGE_TIMEOUT=30.0

# Maximum number of retry attempts
# Default: 3
KGE_MAX_RETRIES=3

# Delay between retries in seconds
# Default: 1.0
KGE_RETRY_DELAY=1.0

# Connection pool size
# Default: 10
KGE_CONNECTION_POOL_SIZE=10

# =============================================================================
# Circuit Breaker Configuration
# =============================================================================

# Number of failures before opening the circuit
# Default: 5
KGE_CIRCUIT_BREAKER_THRESHOLD=5

# Time in seconds before attempting recovery
# Default: 60.0
KGE_CIRCUIT_BREAKER_TIMEOUT=60.0

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# Test-Specific Configuration
# =============================================================================

# Mock server for testing (set to 'true' to use mock responses)
USE_MOCK_SERVER=true

# Test data directory
TEST_DATA_DIR=tests/fixtures

# =============================================================================
# Development Configuration
# =============================================================================

# Enable debug mode
DEBUG=false

# Verbose logging
VERBOSE=false